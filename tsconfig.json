{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@/components/*": ["./components/*"],
			"@/constants/*": ["./constants/*"],
			"@/types/*": ["./types/*"],
			"@/hooks/*": ["./hooks/*"],
			"@/lib/*": ["./lib/*"],
			"@/utils/*": ["./utils/*"]
		},
		// Silence the baseUrl deprecation warning
		"ignoreDeprecations": "6.0"
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts"
	]
}
