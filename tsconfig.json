{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		// set the paths we set our @as our base path then we set some
		// additional path aliasing to prevent paths becoming too long
		"paths": {
			"@/*": ["./*"],
			"@/components/*": ["./components/*"],
			"@/constants/*": ["./constants/*"],
			"@/types/*": ["./types/*"],
			"@/hooks/*": ["./hooks/*"],
			"@/lib/*": ["./lib/*"],
			"@/utils/*": ["./utils/*"]
		},
		// Silence the baseUrl deprecation warning
		"ignoreDeprecations": "6.0"
	},
	// include a list of files for us to type check / compile
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		// tailwind for react native
		"nativewind-env.d.ts"
	]
}
